# frp-manager-lite Docker/Compose environment example
# Copy to .env and change every CHANGE_* value before production use.

# Docker Compose 发布地址和端口。
# 默认 127.0.0.1：仅本机可访问，前面挂 Nginx/Caddy 做 HTTPS 反代。
# 设 0.0.0.0：直接从外网访问（不建议生产裸跑，仅用于测试或无 Nginx 的场景）。
FML_PUBLISH_BIND=127.0.0.1
FML_PUBLISH_PORT=18081

FML_ADMIN_USER=admin
FML_ADMIN_PASSWORD=CHANGE_THIS_STRONG_PASSWORD
FML_PORT_START=20000
FML_PORT_END=20199
FML_DEFAULT_MAX_PORTS=5

FRP_SERVER_ADDR=frp.example.com
FRP_SERVER_PORT=7000
FRP_AUTH_TOKEN=CHANGE_THIS_FRPS_TOKEN

# Optional deployment software license controls
# FML_SOFTWARE_LICENSE_SECRET=CHANGE_THIS_LICENSE_SIGNING_SECRET
# FML_LICENSE_SERVER_URL=https://license.example.com
# FML_LICENSE_AUTHORITY=0
# FML_SOFTWARE_LICENSE_REQUIRED=0

# Optional Cloudflare R2 full-backup upload
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=
# R2_PREFIX=frp-manager-lite/backups
